# Rx Resume — Environment Variables
# Copy this to .env and fill in real values
# Generate secrets with: openssl rand -hex 32

# Database password
DB_PASSWORD=change_me_use_openssl_rand

# MinIO / Storage credentials
STORAGE_ACCESS_KEY=change_me_use_openssl_rand
STORAGE_SECRET_KEY=change_me_use_openssl_rand

# JWT secrets (must be different from each other)
ACCESS_TOKEN_SECRET=change_me_use_openssl_rand
REFRESH_TOKEN_SECRET=change_me_use_openssl_rand_different

# Chrome token (any random string)
CHROME_TOKEN=change_me_use_openssl_rand
